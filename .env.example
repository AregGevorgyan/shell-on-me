# Core domain
NEXT_PUBLIC_APP_DOMAIN=startupshell.org
NEXT_PUBLIC_DEV_APP_DOMAIN=dev.startupshell.org
NEXT_PUBLIC_MONEY_MONIKER=Shell Token

# Firebase (required)
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_APP_ID=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=

# Supabase (required)
NEXT_PUBLIC_SUPABASE_INSTANCE_ID=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# API
NEXT_PUBLIC_API_ENDPOINT=api.startupshell.org

# Email safety mode (recommended)
# true = only send essential emails based on allowlists
MINIMAL_EMAIL_MODE=true

# Comma-separated template IDs allowed when MINIMAL_EMAIL_MODE=true
# Example: ESSENTIAL_EMAIL_TEMPLATES=account-security,account-verification
ESSENTIAL_EMAIL_TEMPLATES=

# Comma-separated subject keywords allowed when MINIMAL_EMAIL_MODE=true
# Keep narrow; defaults include account/security/login style terms.
ESSENTIAL_EMAIL_SUBJECT_KEYWORDS=account,security,verification,password,sign-in,signin,login,otp,2fa

# Mailgun (only if you send any emails)
MAILGUN_KEY=
MAILGUN_DOMAIN=mg.startupshell.org

# Comma-separated recipient domain suffixes allowed for outbound email.
# Keep this restricted for private deployment.
EMAIL_RECIPIENT_ALLOWLIST_DOMAINS=@startupshell.org
